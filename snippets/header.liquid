<div class="announcement-bar" role="region" aria-label="Announcement">
  <div class="announcement-bar__track">
    {%- for i in (1..6) -%}
      <span class="announcement-bar__item">Free worldwide shipping on orders over £75</span>
      <span class="announcement-bar__sep">&middot;</span>
      <span class="announcement-bar__item">250gsm archival matte print</span>
      <span class="announcement-bar__sep">&middot;</span>
      <span class="announcement-bar__item">Limited Edition &middot; World Cup 2026</span>
      <span class="announcement-bar__sep">&middot;</span>
    {%- endfor -%}
  </div>
</div>

<header class="site-header" role="banner">
  <a href="/" class="site-header__logo">
    {{ shop.name }}
  </a>

  <nav class="site-header__nav" role="navigation">
    <a href="/collections/all">Shop All</a>
    <a href="/collections/icon">Icon</a>
    <a href="/collections/nation">Nation</a>
    <a href="/collections/kit">Kit</a>
  </nav>

  <div class="site-header__actions">
    <button class="cart-icon" data-cart-toggle aria-label="Open cart">
      Cart
      <span class="cart-icon__count" style="display:none">0</span>
    </button>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile nav -->
<div class="mobile-nav-overlay"></div>
<nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
  <button class="mobile-nav__close" aria-label="Close menu">&times;</button>
  <a href="/collections/all">Shop All</a>
  <a href="/collections/icon">Icon</a>
  <a href="/collections/nation">Nation</a>
  <a href="/collections/kit">Kit</a>
</nav>
