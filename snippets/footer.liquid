<div class="marquee">
  <div class="marquee__track">
    {%- for i in (1..8) -%}
      <span class="marquee__item">Free worldwide shipping on orders over £75</span>
      <span class="marquee__item">Giclée art print quality</span>
      <span class="marquee__item">250gsm archival matte paper</span>
      <span class="marquee__item">World Cup 2026</span>
    {%- endfor -%}
  </div>
</div>

<footer class="site-footer" role="contentinfo">
  <div>
    <div class="footer-logo">{{ shop.name }}</div>
    <p class="footer-tagline">Limited edition football art prints.<br>32 nations. 4 series.</p>
  </div>

  <div>
    <p class="footer-col__title">Shop</p>
    <ul class="footer-links">
      <li><a href="/collections/all">All Prints</a></li>
      <li><a href="/collections/icon">Icon Series</a></li>
      <li><a href="/collections/nation">Nation Series</a></li>
      <li><a href="/collections/kit">Kit Series</a></li>
    </ul>
  </div>

  <div>
    <p class="footer-col__title">Info</p>
    <ul class="footer-links">
      <li><a href="/pages/about">About</a></li>
      <li><a href="/pages/shipping">Shipping & Returns</a></li>
      <li><a href="/pages/faq">FAQ</a></li>
      <li><a href="/pages/contact">Contact</a></li>
    </ul>
  </div>
</footer>

<div class="footer-bottom">
  <p>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
  <p>Designed for print lovers.</p>
</div>

<!-- Cart Drawer -->
<div class="cart-drawer__overlay"></div>
<div class="cart-drawer" aria-label="Shopping cart">
  <div class="cart-drawer__header">
    <span class="cart-drawer__title">Your Cart</span>
    <button class="cart-drawer__close" aria-label="Close cart">&times;</button>
  </div>

  <div class="cart-drawer__items" id="cart-drawer-items">
    <!-- Rendered by JS via renderCartDrawer() -->
  </div>

  <div class="cart-drawer__footer">
    <div class="cart-total">
      <span class="cart-total__label">Total</span>
      <span class="cart-total__amount" id="cart-drawer-total"></span>
    </div>
    <a href="/checkout" class="cart-checkout">Checkout</a>
  </div>
</div>
