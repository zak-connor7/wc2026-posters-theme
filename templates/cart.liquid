<div class="container section">
  <h1 class="heading-md" style="margin-bottom: 3rem;">Your Cart</h1>

  {%- if cart.item_count == 0 -%}
    <p style="color: var(--color-text-muted); margin-bottom: 2rem;">Your cart is empty.</p>
    <a href="/collections/all" class="btn btn-primary">Shop All Prints</a>
  {%- else -%}
    <div style="display: grid; grid-template-columns: 1fr 360px; gap: 4rem; align-items: start;">

      <div>
        {%- for item in cart.items -%}
          <div class="cart-item">
            <img
              class="cart-item__image"
              src="{{ item.image | img_url: '160x' }}"
              alt="{{ item.title | escape }}"
              width="72"
              loading="lazy"
            >
            <div class="cart-item__info">
              <div>
                <p class="cart-item__name">{{ item.product.title }}</p>
                <p class="cart-item__variant">{{ item.variant.title }}</p>
              </div>
              <div class="cart-item__bottom">
                <div class="cart-item__qty">
                  <button data-cart-qty-change="-1" data-key="{{ item.key }}">-</button>
                  <span>{{ item.quantity }}</span>
                  <button data-cart-qty-change="1" data-key="{{ item.key }}">+</button>
                </div>
                <span class="cart-item__price">{{ item.line_price | money }}</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div style="border: 1px solid var(--color-border); padding: 2rem; position: sticky; top: 100px;">
        <p class="heading-sm" style="margin-bottom: 1.5rem;">Order Summary</p>
        <div class="cart-total" style="margin-bottom: 0.75rem;">
          <span style="font-size: 0.875rem; color: var(--color-text-muted);">Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 1.5rem;">Shipping calculated at checkout</p>
        <a href="/checkout" class="cart-checkout" style="display: block; text-align: center;">
          Checkout
        </a>
        <a href="/collections/all" style="display: block; text-align: center; margin-top: 1rem; font-size: 0.75rem; color: var(--color-text-muted); font-family: var(--font-subheading); letter-spacing: 0.1em; text-transform: uppercase;">
          Continue Shopping
        </a>
      </div>

    </div>
  {%- endif -%}
</div>
