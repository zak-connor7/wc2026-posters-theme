<script>
  window.productVariants = {{ product.variants | json }};
</script>

<!-- Sticky ATC bar (shown when main button scrolls out of view) -->
<div class="sticky-atc" id="sticky-atc" aria-hidden="true">
  <div class="sticky-atc__inner">
    <div class="sticky-atc__product">
      <span class="sticky-atc__title">{{ product.title }}</span>
      <span class="sticky-atc__price" id="sticky-atc-price">{{ product.price | money }}</span>
    </div>
    <button class="sticky-atc__btn" id="sticky-atc-btn" type="button">
      {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
    </button>
  </div>
</div>

<div class="product-page">

  <!-- Gallery -->
  <div class="product-page__gallery">
    {%- if product.featured_image -%}
      <img
        class="product-page__gallery-main"
        id="gallery-main-img"
        src="{{ product.featured_image | img_url: '1200x' }}"
        alt="{{ product.title | escape }}"
        width="1200"
        loading="eager"
      >
    {%- else -%}
      <div class="product-page__gallery-placeholder">
        <span>{{ product.title | escape }}</span>
      </div>
    {%- endif -%}

    {%- if product.images.size > 1 -%}
      <div class="product-page__gallery-thumbs">
        {%- for image in product.images -%}
          <button
            class="gallery-thumb{% if forloop.first %} active{% endif %}"
            type="button"
            data-full="{{ image | img_url: '1200x' }}"
            aria-label="View image {{ forloop.index }}"
          >
            <img
              src="{{ image | img_url: '160x160', crop: 'center' }}"
              alt="{{ image.alt | escape }}"
              width="80"
              height="80"
              loading="lazy"
            >
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Info -->
  <div class="product-page__info">
    <div class="product-page__meta">
      {%- if product.metafields.custom.series != blank -%}
        <span class="product-page__series">{{ product.metafields.custom.series }} Series</span>
      {%- endif -%}
      <span class="product-page__edition">Limited Edition &middot; World Cup 2026</span>
    </div>

    <h1 class="product-page__title">{{ product.title }}</h1>

    <p class="product-page__price" id="product-price">
      {%- if product.compare_at_price > product.price -%}
        <s class="product-page__compare-price">{{ product.compare_at_price | money }}</s>
      {%- endif -%}
      <span id="price-label"><span id="price-from">From </span>{{ product.price | money }}</span>
    </p>

    <div class="product-page__divider"></div>

    <form data-add-to-cart-form action="/cart/add" method="post" enctype="multipart/form-data">
      <input type="hidden" name="form_type" value="product">
      <input type="hidden" name="utf8" value="&#x2713;">

      {%- unless product.has_only_default_variant -%}
        <div class="product-page__variants">
          {%- for option in product.options_with_values -%}
            <div>
              <span class="variant-label">{{ option.name }}</span>
              <div class="variant-options">
                {%- for value in option.values -%}
                  <button
                    type="button"
                    class="variant-btn{% if forloop.first %} selected{% endif %}"
                    data-option="{{ option.position }}"
                    data-value="{{ value }}"
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <select name="id" style="display:none">
          {%- for variant in product.variants -%}
            <option value="{{ variant.id }}"{% if variant.available == false %} disabled{% endif %}>
              {{ variant.title }}
            </option>
          {%- endfor -%}
        </select>
      {%- else -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      {%- endunless -%}

      <button
        type="submit"
        class="product-page__add"
        id="main-atc-btn"
        {% unless product.available %}disabled{% endunless %}
      >
        {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>
    </form>

    <!-- Trust strip -->
    <div class="product-trust-strip">
      <span class="product-trust-item">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1L8.8 5.2L13.5 5.6L10 8.6L11 13L7 10.6L3 13L4 8.6L0.5 5.6L5.2 5.2L7 1Z" fill="currentColor"/></svg>
        250gsm archival paper
      </span>
      <span class="product-trust-sep">&middot;</span>
      <span class="product-trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.97 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" fill="currentColor"/></svg>
        Ships 3&ndash;7 days
      </span>
      <span class="product-trust-sep">&middot;</span>
      <span class="product-trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="currentColor"/></svg>
        Made to order
      </span>
    </div>

    <div class="product-page__divider"></div>

    {%- if product.description != blank -%}
      <div class="body-sm product-page__desc">{{ product.description }}</div>
      <div class="product-page__divider"></div>
    {%- endif -%}

    <div class="product-page__details">
      <div class="product-detail">
        <div class="product-detail__header">
          <span class="product-detail__label">Print details</span>
          <span class="product-detail__icon">+</span>
        </div>
        <div class="product-detail__content">
          Archival matte paper, 250gsm. Acid-free, off-white stock. Printed to giclee standard. Colours are deep and accurate from edge to edge.
        </div>
      </div>
      <div class="product-detail">
        <div class="product-detail__header">
          <span class="product-detail__label">Sizes</span>
          <span class="product-detail__icon">+</span>
        </div>
        <div class="product-detail__content">
          A4 (210 x 297mm) &middot; A3 (297 x 420mm) &middot; A2 (420 x 594mm). Framing available in A3 and A2 in Black, White, or Natural Wood. Unframed prints shipped rolled in a protective tube.
        </div>
      </div>
      <div class="product-detail open">
        <div class="product-detail__header">
          <span class="product-detail__label">Shipping</span>
          <span class="product-detail__icon">+</span>
        </div>
        <div class="product-detail__content">
          Ships worldwide. Estimated 3&ndash;7 business days depending on location. Free shipping on orders over £75.
        </div>
      </div>
    </div>
  </div>

</div>
