<script>
  window.productVariants = {{ product.variants | json }};
</script>

<div class="product-page">

  <!-- Gallery -->
  <div class="product-page__gallery">
    {%- if product.featured_image -%}
      <img
        class="product-page__gallery-main"
        src="{{ product.featured_image | img_url: '1200x' }}"
        alt="{{ product.title | escape }}"
        width="1200"
        loading="eager"
      >
    {%- else -%}
      <div class="product-page__gallery-placeholder">
        <span>{{ product.title | escape }}</span>
      </div>
    {%- endif -%}
    {%- if product.images.size > 1 -%}
      <div class="product-page__gallery-thumbs">
        {%- for image in product.images -%}
          <img
            class="gallery-thumb{% if forloop.first %} active{% endif %}"
            src="{{ image | img_url: '80x80', crop: 'center' }}"
            alt="{{ image.alt | escape }}"
            width="56"
            height="56"
            loading="lazy"
          >
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Info -->
  <div class="product-page__info">
    {%- if product.metafields.custom.series != blank -%}
      <p class="product-page__series">{{ product.metafields.custom.series }} Series</p>
    {%- endif -%}

    <h1 class="product-page__title">{{ product.title }}</h1>

    <p class="product-page__price" id="product-price">
      {%- if product.compare_at_price > product.price -%}
        <s style="color: var(--color-text-subtle);">{{ product.compare_at_price | money }}</s>&nbsp;
      {%- endif -%}
      <span id="price-label"><span id="price-from">From </span>{{ product.price | money }}</span>
    </p>

    <div class="product-page__divider"></div>

    <form data-add-to-cart-form action="/cart/add" method="post" enctype="multipart/form-data">
      <input type="hidden" name="form_type" value="product">
      <input type="hidden" name="utf8" value="&#x2713;">

      {%- unless product.has_only_default_variant -%}
        <div class="product-page__variants">
          {%- for option in product.options_with_values -%}
            <div>
              <span class="variant-label">{{ option.name }}</span>
              <div class="variant-options">
                {%- for value in option.values -%}
                  <button
                    type="button"
                    class="variant-btn{% if forloop.first %} selected{% endif %}"
                    data-option="{{ option.position }}"
                    data-value="{{ value }}"
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <select name="id" style="display:none">
          {%- for variant in product.variants -%}
            <option value="{{ variant.id }}"{% if variant.available == false %} disabled{% endif %}>
              {{ variant.title }}
            </option>
          {%- endfor -%}
        </select>
      {%- else -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      {%- endunless -%}

      <button
        type="submit"
        class="product-page__add"
        {% unless product.available %}disabled{% endunless %}
      >
        {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>
    </form>

    <div class="product-page__divider"></div>

    {%- if product.description != blank -%}
      <div class="body-sm" style="color: var(--color-text-muted); line-height: 1.8;">
        {{ product.description }}
      </div>
      <div class="product-page__divider"></div>
    {%- endif -%}

    <div class="product-page__details">
      <div class="product-detail">
        <div class="product-detail__header">
          <span class="product-detail__label">Print details</span>
          <span class="product-detail__icon">+</span>
        </div>
        <div class="product-detail__content">
          Archival matte paper, 250gsm. Acid-free, off-white stock. Printed to giclee standard. Colours are deep and accurate from edge to edge.
        </div>
      </div>
      <div class="product-detail">
        <div class="product-detail__header">
          <span class="product-detail__label">Sizes</span>
          <span class="product-detail__icon">+</span>
        </div>
        <div class="product-detail__content">
          A4 (210 x 297mm) · A3 (297 x 420mm) · A2 (420 x 594mm). Framing available in A3 and A2 in Black, White, or Natural Wood. Unframed prints shipped rolled in a protective tube.
        </div>
      </div>
      <div class="product-detail">
        <div class="product-detail__header">
          <span class="product-detail__label">Shipping</span>
          <span class="product-detail__icon">+</span>
        </div>
        <div class="product-detail__content">
          Ships worldwide. Estimated 3-7 business days depending on location. Each print is produced to order.
        </div>
      </div>
    </div>
  </div>

</div>
