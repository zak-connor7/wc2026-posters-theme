<div class="hero">
  <div class="hero__bg">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | img_url: '2000x' }}"
        alt=""
        width="2000"
        loading="eager"
      >
    {%- endif -%}
  </div>

  <div class="hero__content container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h1 class="hero__title heading-xl">
      {{ section.settings.title | newline_to_br }}
    </h1>

    {%- if section.settings.subtitle != blank -%}
      <p class="hero__subtitle body-lg">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="hero__actions">
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url }}" class="btn btn-primary">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url }}" class="btn btn-secondary">
          {{ section.settings.cta_secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "World Cup 2026"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "32 Nations.\nLimited Edition."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Fine art football posters. Printed on demand."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Shop All Prints"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label",
      "default": "View Series"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
